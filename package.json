{
  "name": "pptx-kit",
  "version": "0.6.3",
  "description": "Generate and edit .pptx (OOXML PresentationML) files from TypeScript, in Node and the browser.",
  "keywords": [
    "drawingml",
    "ecma-376",
    "office",
    "ooxml",
    "powerpoint",
    "pptx",
    "presentation",
    "presentationml"
  ],
  "homepage": "https://github.com/baseballyama/pptx-kit#readme",
  "bugs": {
    "url": "https://github.com/baseballyama/pptx-kit/issues"
  },
  "license": "MIT",
  "author": "Yuichiro Yamashita",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/baseballyama/pptx-kit.git"
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE",
    "CHANGELOG.md"
  ],
  "type": "module",
  "sideEffects": false,
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./node": {
      "types": "./dist/node.d.ts",
      "import": "./dist/node.js"
    },
    "./package.json": "./package.json"
  },
  "publishConfig": {
    "access": "public",
    "provenance": true
  },
  "scripts": {
    "build": "tsdown",
    "dev": "tsdown --watch",
    "typecheck": "tsc --noEmit",
    "lint": "oxlint",
    "lint:fix": "oxlint --fix",
    "format": "oxfmt --write",
    "format:check": "oxfmt --check",
    "test": "vitest run",
    "test:watch": "vitest",
    "samples": "GENERATE_SAMPLES=1 vitest run test/samples-generate.test.ts",
    "bench": "PERF=1 vitest run test/perf-bench.test.ts",
    "changeset": "changeset",
    "release": "changeset publish",
    "prepublishOnly": "pnpm run build"
  },
  "dependencies": {
    "fflate": "^0.8.3"
  },
  "devDependencies": {
    "@changesets/cli": "^2.31.0",
    "@types/node": "^20.19.43",
    "esbuild": "^0.28.1",
    "oxfmt": "^0.54.0",
    "oxlint": "^1.69.0",
    "tsdown": "^0.22.2",
    "typescript": "^6.0.3",
    "vitest": "^2.1.9"
  },
  "engines": {
    "node": ">=22.22.3"
  },
  "packageManager": "pnpm@10.34.3"
}
