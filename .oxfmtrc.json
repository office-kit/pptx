{
  "$schema": "./node_modules/oxfmt/configuration_schema.json",
  "useTabs": false,
  "tabWidth": 2,
  "printWidth": 100,
  "endOfLine": "lf",
  "singleQuote": true,
  "quoteProps": "as-needed",
  "trailingComma": "all",
  "semi": true,
  "arrowParens": "always",
  "bracketSpacing": true,
  "ignorePatterns": [
    "dist/**",
    "coverage/**",
    "node_modules/**",
    ".changeset/**",
    "references/**",
    "test/fixtures/**"
  ]
}
