{
  "name": "pptx-kit-preview",
  "version": "0.6.1",
  "description": "Experimental preview renderer for pptx-kit: render a slide to SVG (browser + Node) or rasterize it to a PNG/RGBA image in Node, with no browser binary.",
  "keywords": [
    "ooxml",
    "png",
    "powerpoint",
    "pptx",
    "preview",
    "render",
    "svg"
  ],
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/baseballyama/pptx-kit.git",
    "directory": "packages/preview"
  },
  "files": [
    "dist",
    "fonts",
    "README.md"
  ],
  "type": "module",
  "sideEffects": false,
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./node": {
      "types": "./dist/node.d.ts",
      "import": "./dist/node.js"
    },
    "./package.json": "./package.json"
  },
  "publishConfig": {
    "access": "public",
    "provenance": true
  },
  "scripts": {
    "build": "tsdown",
    "typecheck": "tsc --noEmit",
    "prepublishOnly": "tsdown"
  },
  "dependencies": {
    "@resvg/resvg-js": "^2.6.2",
    "fontkit": "^2.0.4"
  },
  "devDependencies": {
    "@types/fontkit": "^2.0.9",
    "pptx-kit": "workspace:*",
    "tsdown": "^0.22.2",
    "typescript": "^6.0.3"
  },
  "peerDependencies": {
    "pptx-kit": ">=0.6.3"
  },
  "engines": {
    "node": ">=22.18.0"
  }
}
