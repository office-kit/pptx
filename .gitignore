# Manual-inspection PPTX output (regenerated by `pnpm samples`).
samples/out/

.claude/worktrees/

# Preview-fidelity harness output (regenerated by `pnpm --filter @office-kit/pptx-site fidelity`).
# `--out` may target out/, out-pp/, out-ours/, … — ignore every variant.
site/fidelity/out*/
# Candidate baseline produced by --check on every run; commit as baseline.json to update the gate.
site/fidelity/baseline.candidate.json

# corpus harness output
test/corpus/out/

# Local scratch probes (not part of the package)
.probe/
