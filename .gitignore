node_modules
dist
coverage
.vitest-cache

# Spec downloads — references/specs/fetch.sh fetches into here. Not redistributed.
references/specs/downloads/
references/specs/xsd/

# Local cloning of external (large / copyleft) references — see references/EXTERNAL.md.
references/external/

# Claude Code session lock files
.claude/*.lock

.DS_Store
*.log
.env
.env.local

.idea
.vscode
